# --- App ---
APP_NAME=Otfit
BASE_URL=http://localhost:8000
# Flutter 웹 로컬 dev 서버 허용 (localhost/127.0.0.1 모든 포트)
# 로컬 개발 기본값. Cloudtype 배포 시 예:
#   ^(https://.*\.cloudtype\.app|http://localhost(:\d+)?)$
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
SECRET_KEY=change-me-in-production-to-a-long-random-string-32b+
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Social Login ---
# 설정 시 구글 id_token의 aud 검증. 카카오는 서버 측 키 불필요(클라이언트 SDK 토큰 검증만).
GOOGLE_CLIENT_ID=

# --- Database / Queue ---
DATABASE_URL=postgresql+asyncpg://otfit:otfit@postgres:5432/otfit
SYNC_DATABASE_URL=postgresql+psycopg2://otfit:otfit@postgres:5432/otfit
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_DIR=/data/media
# S3 호환(R2) — 상품 이미지 공개 서빙(R2_PUBLIC_URL) + 사용자 사진 presigned URL 생성
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=auto
R2_PUBLIC_URL=

# --- Providers: mock | live ---
PROVIDER_MODE=mock
# 컴포넌트별 오버라이드 (비우면 PROVIDER_MODE를 따름).
# GENERATION_PROVIDER: mock | segmind(=live) | openai(gpt-image-1 편집)
# 하이브리드 데모 예시 — 분석·추천은 mock, 실제 옷 교체만 실호출:
# VISION_PROVIDER=mock
# EMBEDDING_PROVIDER=mock
# GENERATION_PROVIDER=segmind
VISION_PROVIDER=
EMBEDDING_PROVIDER=
GENERATION_PROVIDER=
# 유해 이미지 차단 (나체·폭력 등): mock | openai — openai면 OPENAI_API_KEY 필요
MODERATION_PROVIDER=
# live 의상 생성: Segmind IDM-VTON
SEGMIND_API_KEY=
# live 분석/임베딩: OpenAI. mock은 키 없이 전체 플로우 동작.
OPENAI_API_KEY=
VISION_MODEL=gpt-5.6-sol
IMAGE_MODEL=gpt-image-1
EMBEDDING_MODEL=text-embedding-3-small

# --- Policy ---
SIGNUP_BONUS_CREDITS=3
GENERATION_COST_CREDITS=1
PHOTO_RETENTION_DAYS=30
EMBEDDING_DIM=512
COMPOSE_PROJECT_NAME=otfit
