# --- App ---
APP_NAME=Otfit
BASE_URL=http://localhost:8000
# Flutter 웹 로컬 dev 서버 허용 (localhost/127.0.0.1 모든 포트)
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
SECRET_KEY=change-me-in-production-to-a-long-random-string-32b+
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database / Queue ---
DATABASE_URL=postgresql+asyncpg://otfit:otfit@postgres:5432/otfit
SYNC_DATABASE_URL=postgresql+psycopg2://otfit:otfit@postgres:5432/otfit
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_DIR=/data/media
# S3 호환(R2) — live 모드에서 Segmind이 사용자 사진을 가져갈 presigned URL 생성에 필요
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

# --- Providers: mock | live ---
PROVIDER_MODE=mock
# 컴포넌트별 오버라이드 (비우면 PROVIDER_MODE를 따름). 하이브리드 데모 예시:
#   분석·추천은 mock, 실제 옷 교체만 Segmind 실호출
# VISION_PROVIDER=mock
# EMBEDDING_PROVIDER=mock
# GENERATION_PROVIDER=live
VISION_PROVIDER=
EMBEDDING_PROVIDER=
GENERATION_PROVIDER=
# live 의상 생성: Segmind IDM-VTON
SEGMIND_API_KEY=
# live 분석/임베딩: OpenAI. mock은 키 없이 전체 플로우 동작.
OPENAI_API_KEY=
VISION_MODEL=gpt-5.6-sol
IMAGE_MODEL=gpt-image-1
EMBEDDING_MODEL=text-embedding-3-small

# --- Policy ---
SIGNUP_BONUS_CREDITS=10
GENERATION_COST_CREDITS=1
PHOTO_RETENTION_DAYS=30
EMBEDDING_DIM=512
COMPOSE_PROJECT_NAME=otfit
