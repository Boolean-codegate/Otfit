# --- App ---
APP_NAME=Otfit
BASE_URL=http://localhost:8000
# Flutter 웹 로컬 dev 서버 허용 (localhost/127.0.0.1 모든 포트)
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
SECRET_KEY=change-me-in-production-to-a-long-random-string-32b+
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Social Login ---
# 설정 시 구글 id_token의 aud 검증. 카카오는 서버 측 키 불필요(클라이언트 SDK 토큰 검증만).
GOOGLE_CLIENT_ID=

# --- Database / Queue ---
DATABASE_URL=postgresql+asyncpg://otfit:otfit@postgres:5432/otfit
SYNC_DATABASE_URL=postgresql+psycopg2://otfit:otfit@postgres:5432/otfit
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_DIR=/data/media

# --- Providers: mock | live ---
PROVIDER_MODE=mock
# live 모드(OpenAI)에서만 필요. mock은 키 없이 전체 플로우 동작.
OPENAI_API_KEY=
VISION_MODEL=gpt-5.6-sol
IMAGE_MODEL=gpt-image-1
EMBEDDING_MODEL=text-embedding-3-small

# --- Policy ---
SIGNUP_BONUS_CREDITS=10
GENERATION_COST_CREDITS=1
PHOTO_RETENTION_DAYS=30
EMBEDDING_DIM=512
COMPOSE_PROJECT_NAME=otfit
